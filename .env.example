# Windsor.ai — one API key covers Google Ads, Meta, and GA4
WINDSOR_API_KEY=

# Per-source account identifiers from Windsor. Format: {connector}__{account_name}.
WINDSOR_GOOGLE_ADS_ACCOUNT_ID=
WINDSOR_META_AD_ACCOUNT_ID=

# Case-insensitive substring — Meta campaigns matching this are excluded from
# spend totals (Bolt Coaching campaigns are not part of the rental business).
# Set to empty string to disable.
META_EXCLUDE_CAMPAIGN_PATTERN=coaching

# Comma-separated GA4 hostnames to exclude from visitor totals. Used to strip
# subdomain traffic that doesn't represent the main site (e.g. an internal
# explore tool). Leave empty to include all hostnames.
GA4_EXCLUDE_HOSTNAMES=explore.boltfarmtreehouse.com
WINDSOR_GA4_PROPERTY_ID=

# HubSpot — direct REST API (not via Windsor).
# Private app token from: HubSpot → Settings → Integrations → Private Apps.
# Scopes needed: crm.objects.deals.read, crm.schemas.deals.read, crm.pipelines.read
HUBSPOT_ACCESS_TOKEN=

# Name of the HubSpot lead pipeline whose entries count as qualified leads.
HUBSPOT_PIPELINE_NAME=Lead pipeline

# Comma-separated owner display names (or emails, or team names) to exclude.
# Leads assigned to these owners are NOT counted as qualified.
HUBSPOT_EXCLUDED_OWNER_NAMES=Bolt Coaching

# Optional — filter to a specific stage in the pipeline. Leave empty to count
# all leads regardless of stage.
HUBSPOT_QUALIFIED_STAGE=
