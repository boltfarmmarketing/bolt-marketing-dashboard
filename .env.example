# ─────────────────────────────────────────────────────────────
# Bolt Farm Marketing Analytics Dashboard — environment
# Copy to .env.local for local dev. Set the same keys in Vercel
# (Project → Settings → Environment Variables) for production.
# ─────────────────────────────────────────────────────────────

# --- Database (production persistence) -------------------------
# Neon Postgres connection string (Vercel Marketplace → Neon).
# If unset, the app runs read-only from committed seed JSON, and
# the admin form writes to local files under /data/store (dev only).
DATABASE_URL=

# --- Admin form login ------------------------------------------
# Password for /admin. Anything non-empty enables the admin login.
ADMIN_PASSWORD=change-me
# Secret used to sign the admin session cookie (any long random string).
ADMIN_SESSION_SECRET=change-me-to-a-long-random-string

# --- Cron protection -------------------------------------------
# Vercel sends "Authorization: Bearer <CRON_SECRET>" to cron routes.
# Generate with: openssl rand -hex 32
CRON_SECRET=

# --- Windsor.ai (GA4 + Google Ads + Meta Ads) ------------------
# API key from windsor.ai → API → "API Key".
WINDSOR_API_KEY=
# GA4 property / connector account id as configured in Windsor.
WINDSOR_GA4_CONNECTOR=ga4
WINDSOR_GOOGLEADS_CONNECTOR=google_ads
WINDSOR_META_CONNECTOR=facebook

# --- HubSpot ---------------------------------------------------
# Private App token (HubSpot → Settings → Integrations → Private Apps).
HUBSPOT_TOKEN=
